<mujoco model="diff_drive_push">
  <option timestep="0.02" />

  <asset>
    <texture name="blue_grid" type="2d" builtin="checker" rgb1=".02 .14 .44" rgb2=".27 .55 1" width="300" height="300" mark="edge" markrgb="1 1 1"/>
    <material name="blue_grid" texture="blue_grid" texrepeat="1 1" texuniform="true" reflectance=".2"/>
  </asset>

  <worldbody>
    <body>
      <geom mass="0" name="floor" pos="0 0 -0.25" condim="3" size="10.0 10.0 0.10" rgba="0 1 1 1" type="box" material="blue_grid"/>
    </body>

    <body name="pusher" pos="0 0 0">
      <joint name="pusher_x" damping="8" type="slide" axis="1 0 0" />
      <joint name="pusher_y" damping="8" type="slide" axis="0 1 0" />
      <joint name="pusher_theta" damping="2" type="hinge" axis="0 0 1" />
      <!-- friction must be > 0; zero friction causes NaN in mujoco_warp contact solver -->
      <geom name="pusher" type="cylinder" size="0.13 0.1" mass="1" rgba=".9 .5 .5 1" friction="0.01"/>
      <!-- heading marker so the facing direction is visible -->
      <geom name="pusher_nose" type="box" pos="0.13 0 0" size="0.09 0.04 0.06" rgba=".95 .85 .2 1" mass="0" contype="0" conaffinity="0"/>
      <site pos="0 0 0.15" name="pusher_site"/>
    </body>

    <body name="cart" pos="0 0 0">
      <joint name="slider_cart_x" damping="4" type="slide" axis="1 0 0" />
      <joint name="slider_cart_y" damping="4" type="slide" axis="0 1 0" />
      <!-- friction must be > 0; zero friction causes NaN in mujoco_warp contact solver -->
      <geom name="cart" type="cylinder" size="0.25 0.1" mass="1" rgba=".1 .5 .5 1" friction="0.01"/>
      <site pos="0 0 0.15" name="cart_site"/>
    </body>
  </worldbody>

  <actuator>
    <!-- Forward drive: velocity servo applied along the pusher heading (site local x-axis).
         This lets the pusher move along its heading without drifting sideways. -->
    <velocity name="actuator_forward" site="pusher_site" gear="1 0 0 0 0 0" kv="20" ctrlrange="-2 2" forcerange="-1000 1000"/>
    <!-- Heading: position control on the pusher's turning joint. -->
    <position name="actuator_heading" joint="pusher_theta" kp="10" ctrlrange="-10 10" forcerange="-1000 1000"/>
  </actuator>

  <sensor>
    <framepos name="trace_pusher" objtype="site" objname="pusher_site"/>
    <framexaxis name="pusher_heading" objtype="site" objname="pusher_site"/>
    <framelinvel name="pusher_linvel" objtype="site" objname="pusher_site"/>
    <frameangvel name="pusher_angvel" objtype="site" objname="pusher_site"/>
    <framepos name="trace_cart" objtype="site" objname="cart_site"/>
  </sensor>

</mujoco>
